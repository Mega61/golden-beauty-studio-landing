# Golden Beauty Studio — local environment template
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored by Next.js defaults.

# ─────────────────────────────────────────────────────────────────────────────
# Canonical site URL
# ─────────────────────────────────────────────────────────────────────────────
# Used for canonical/hreflang tags, sitemap.xml, and robots.txt. MUST be the
# real production origin (no trailing slash). On Vercel previews the value is
# still emitted as the production URL — that's intentional, so previews never
# compete with production for canonicalization in Google's index.
# Leave unset to fall back to the hard-coded default in src/config/site.ts.
NEXT_PUBLIC_SITE_URL=https://goldenbeautystudio.com.co

# ─────────────────────────────────────────────────────────────────────────────
# Booking — AgendaPro
# ─────────────────────────────────────────────────────────────────────────────
# Public booking URL. Found in your AgendaPro dashboard → "Compartir tu agenda".
# Examples:
#   https://www.agendapro.com/co/goldenbeauty
#   https://goldenbeauty.agendapro.com
# Leave unset to hide all booking CTAs site-wide.
NEXT_PUBLIC_BOOKING_URL=

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Business
# ─────────────────────────────────────────────────────────────────────────────
# International format, no `+`, no spaces. Colombia country code is 57.
# Example for +57 300 123 4567 → 573001234567
# Leave unset to hide all WhatsApp buttons.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Pre-filled message shown when the visitor lands on WhatsApp.
NEXT_PUBLIC_WHATSAPP_GREETING=Hola Golden, quiero información

# ─────────────────────────────────────────────────────────────────────────────
# Social profiles
# ─────────────────────────────────────────────────────────────────────────────
# Public URLs for the social icons in Contacto. Leave a value unset to render
# the label without a link (it falls back to plain text, dimmed).
# Examples:
#   https://www.instagram.com/goldenbeauty
#   https://www.tiktok.com/@goldenbeauty
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Google Maps — Embed API
# ─────────────────────────────────────────────────────────────────────────────
# Setup steps (~5 minutes):
#   1. Go to https://console.cloud.google.com → create or pick a project.
#   2. APIs & Services → Library → search "Maps Embed API" → Enable.
#      The Maps Embed API has NO usage charges — it's the only free Maps API.
#   3. APIs & Services → Credentials → Create credentials → API key.
#   4. RESTRICT THE KEY (important — prevents abuse if leaked):
#        • Application restrictions: HTTP referrers (web sites) → add:
#            http://localhost:3000/*
#            https://YOUR-PRODUCTION-DOMAIN/*
#        • API restrictions: Restrict key → check ONLY "Maps Embed API".
#   5. Paste the key below.
# Leave unset to fall back to the decorative SVG map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# What to show on the map. Either an address or coordinates ("lat,lng").
# Examples:
#   Golden Beauty Studio, Sabaneta, Antioquia
#   6.1573,-75.6166
NEXT_PUBLIC_GOOGLE_MAPS_QUERY=

# (Optional, recommended) Google Business Profile Place ID.
# When set, the iframe pins your exact business listing (with the BP info card),
# and the "Abrir en Google Maps" link deep-links to that listing instead of a
# generic address search. Falls back to NEXT_PUBLIC_GOOGLE_MAPS_QUERY if unset.
#
# How to find your Place ID:
#   1. Go to https://developers.google.com/maps/documentation/places/web-service/place-id
#   2. Use the "Place ID Finder" tool, search for your business, click the marker.
#   3. Copy the value starting with "ChIJ..." (or sometimes "GhIJ...").
# Example: ChIJN1t_tDeuEmsRUsoyG83frY4
NEXT_PUBLIC_GOOGLE_MAPS_PLACE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID
# ─────────────────────────────────────────────────────────────────────────────
# Find in Google Analytics → Admin → Data Streams → your web stream.
# Starts with "G-". Leave unset to disable analytics entirely.
# Wired via @next/third-parties/google's <GoogleAnalytics> (loaded after
# hydration, automatically tracks SPA pageviews on app-router route changes).
NEXT_PUBLIC_GA_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Section visibility — set to "false" to hide. Default is ON when unset.
# Hero, Nav, Footer, FloatingActions are NOT toggleable (page identity).
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SECTION_LOOKBOOK=true       # Editorial mosaic of nail looks
NEXT_PUBLIC_SECTION_SERVICIOS=true      # Service menu with prices
NEXT_PUBLIC_SECTION_DICCIONARIO=true    # Technique glossary (dark section)
NEXT_PUBLIC_SECTION_TECNICAS=true       # Artist portraits
NEXT_PUBLIC_SECTION_ESTUDIO=true        # About + space + hygiene
NEXT_PUBLIC_SECTION_CONTACTO=true       # Address, hours, map, channels
